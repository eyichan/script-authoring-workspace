generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ProjectStatus {
  active
  trashed
}

enum ScriptBlockType {
  scene
  action
  character
  paren
  dialogue
  transition
  comment
  subtitle
}

enum AssetTaskKind {
  movie_poster
  casting_poster
  concept_trailer
  scene_dramatization
  director_roundtable
  script_table_read
}

enum AssetTaskStatus {
  queued
  running
  done
  failed
}

model Project {
  id            String                @id
  title         String
  status        ProjectStatus         @default(active)
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  trashedAt     DateTime?
  scripts       Script[]
  share         ProjectShare?
  collaborators ProjectCollaborator[]
}

model ProjectShare {
  projectId String   @id
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model ProjectCollaborator {
  id        String   @id
  projectId String
  initials  String
  role      String
  status    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model Script {
  id                   String                @id
  projectId            String
  title                String
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  project              Project               @relation(fields: [projectId], references: [id], onDelete: Cascade)
  blocks               ScriptBlock[]
  beats                Beat[]
  props                Prop[]
  assetTasks           AssetTask[]
  characterProfiles    CharacterProfile[]
  sceneProductionNotes SceneProductionNote[]
  locationProfiles     LocationProfile[]
  outline              ScriptOutline?
  cover                ScriptCover?

  @@index([projectId])
}

model ScriptBlock {
  id        String          @id
  scriptId  String
  type      ScriptBlockType
  text      String          @default("")
  position  Int
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  script    Script          @relation(fields: [scriptId], references: [id], onDelete: Cascade)

  @@unique([scriptId, position])
  @@index([scriptId])
}

model Beat {
  id              String   @id
  scriptId        String
  title           String
  description     String
  color           String
  durationMinutes Int
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  script          Script   @relation(fields: [scriptId], references: [id], onDelete: Cascade)

  @@index([scriptId])
}

model Prop {
  id          String   @id
  scriptId    String
  name        String
  themeColor  String   @default("racing-green")
  category    String
  description String
  imageNote   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  script      Script   @relation(fields: [scriptId], references: [id], onDelete: Cascade)

  @@index([scriptId])
}

model CharacterProfile {
  id              String   @id
  scriptId        String
  characterId     String
  displayName     String
  color           String   @default("racing-green")
  gender          String   @default("Not Set")
  age             String   @default("")
  role            String   @default("")
  bio             String   @default("")
  appearanceNotes String   @default("")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  script          Script   @relation(fields: [scriptId], references: [id], onDelete: Cascade)

  @@unique([scriptId, characterId])
  @@index([scriptId])
}

model SceneProductionNote {
  id              String   @id
  scriptId        String
  sceneId         String
  description     String   @default("")
  artRequirements String   @default("")
  stillStatus     String   @default("Pending")
  videoStatus     String   @default("Pending")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  script          Script   @relation(fields: [scriptId], references: [id], onDelete: Cascade)

  @@unique([scriptId, sceneId])
  @@index([scriptId])
}

model LocationProfile {
  id              String   @id
  scriptId        String
  locationId      String
  displayName     String
  address         String   @default("")
  description     String   @default("")
  scoutingStatus  String   @default("Pending")
  ownerName       String   @default("")
  phone           String   @default("")
  email           String   @default("")
  dailyRental     String   @default("")
  deposit         String   @default("")
  currency        String   @default("USD")
  availableFrom   String   @default("")
  availableUntil  String   @default("")
  shootingHours   String   @default("")
  notes           String   @default("")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  script          Script   @relation(fields: [scriptId], references: [id], onDelete: Cascade)

  @@unique([scriptId, locationId])
  @@index([scriptId])
}

model ScriptOutline {
  scriptId  String   @id
  text      String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  script    Script   @relation(fields: [scriptId], references: [id], onDelete: Cascade)
}

model ScriptCover {
  scriptId  String   @id
  title     String
  writtenBy String   @default("")
  draftDate String   @default("")
  contact   String   @default("")
  notes     String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  script    Script   @relation(fields: [scriptId], references: [id], onDelete: Cascade)
}

model AssetTask {
  id        String          @id
  scriptId  String
  kind      AssetTaskKind
  title     String
  status    AssetTaskStatus @default(queued)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  script    Script          @relation(fields: [scriptId], references: [id], onDelete: Cascade)

  @@index([scriptId])
  @@index([status])
}
